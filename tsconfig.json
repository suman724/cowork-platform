{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "generated/typescript/src/**/*.ts",
    "sdk/typescript/src/**/*.ts",
    "tests/typescript/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
