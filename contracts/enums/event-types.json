    "tool_output_chunk",
    "approval_requested",
    "approval_resolved",
    "policy_expired",
    "task_completed",
    "task_failed",
    "llm_retry",
    "context_compacted",
    "session_completed",
    "session_failed",
    "sandbox_provisioning",
    "sandbox_ready",
    "sandbox_terminated",
    "sandbox_shutting_down",
